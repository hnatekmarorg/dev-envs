# Debian Development Environment Task Runner
# Install just: https://github.com/casey/just

# Detect container builder (docker or podman)
_container-builder:
  #!/usr/bin/env bash
  which docker >/dev/null && echo "docker" || echo "podman"

# Get the container builder as a variable
container-builder := "`just _container-builder`"

# Incus VM image
_IMAGE := "images:debian/13/cloud"

# Default recipes
default:
  @just --list

# Show help
help: default

# Container recipes

# Build image with your UID/GID
build:
  @echo "==> Building image with your UID/GID using {{container-builder}}..."
  {{container-builder}} build -t debian-dev  \
    --build-arg USER_UID=$(id -u) \
    --build-arg USER_GID=$(id -g) \
    .

# Build image with default UID/GID (1000)
build-default:
  @echo "==> Building image with default UID/GID (1000) using {{container-builder}}..."
  {{container-builder}} build --no-cache -t debian-dev .

# Remove image
clean:
  @echo "==> Removing image using {{container-builder}}..."
  {{container-builder}} rmi debian-dev 2>/dev/null || echo "Image not found"

# Run container (builds first)
run: build
  @echo "==> Running container using {{container-builder}}..."
  @{{container-builder}} rm -f debian-dev 2>/dev/null || true
  @{{container-builder}} run -it --rm --name debian-dev \
    --device /dev/fuse \
    --security-opt seccomp=unconfined \
    --security-opt apparmor=unconfined \
    -v "/data/documents/:/data/documents" \
    debian-dev

# Run container detached
run-bg: build
  @echo "==> Running container in background using {{container-builder}}..."
  @{{container-builder}} rm -f debian-dev 2>/dev/null || true
  @{{container-builder}} run -d \
    --name debian-dev \
    --restart unless-stopped \
    --network host \
    --gpus all \
    --device /dev/fuse \
    --security-opt seccomp=unconfined \
    --security-opt apparmor=unconfined \
    -v "/data/documents/:/data/documents" \
    debian-dev

# Stop and remove container
destroy:
  @echo "==> Removing container using {{container-builder}}..."
  @{{container-builder}} rm -f debian-dev 2>/dev/null || echo "Container not found"

# Incus/VM recipes

# VM configuration defaults
_VM_NAME := "debian-dev"
_VM_CPU := "4"
_VM_MEMORY := "16GiB"

# VM resource presets
_VM_CPU_SMALL := "2"
_VM_MEMORY_SMALL := "8GiB"
_VM_CPU_LARGE := "8"
_VM_MEMORY_LARGE := "32GiB"

# LXD Container configuration
_LXD_NAME := "debian-lxd-dev"

# Create Debian profile (VM)
create:
  @echo "==> Creating Debian base profile..."
  @incus profile create debian-dev 2>/dev/null || echo "Profile already exists"
  @incus profile set debian-dev cloud-init.user-data="$(cat ./cloud-init.yaml)"
  @echo "==> Profile created. Launch VM with:"
  @echo "    incus launch --vm {{_IMAGE}} <vm-name> -p default -p debian-dev"
  @echo ""
  @echo "Or with custom CPU/memory:"
  @echo "    just vm create-custom <name> <cpu> <memory>"

# Create LXD container profile (nested Docker + GPU)
lxd-create:
	@echo "==> Creating LXD container profile with Docker + GPU support..."
	@incus profile create debian-lxd 2>/dev/null || echo "Profile exists"
	@incus profile set debian-lxd cloud-init.user-data="$(cat ./cloud-init-lxd.yaml)"
	@incus profile set debian-lxd security.nesting true
	@incus profile set debian-lxd security.privileged true
	@incus profile device add debian-lxd gpu gpu 2>/dev/null || echo "GPU device added"
	@echo ""
	@echo "==> LXD profile created. Launch container with:"
	@echo "    just lxd-run <container-name>"
	@echo "    # or manually:"
	@echo "    incus launch images:debian/13/cloud <name> -p default -p debian-lxd"

# Launch LXD container with Docker + GPU
lxd-run name:
	#!/usr/bin/env bash
	CONTAINER_NAME="{{name}}"
	
	echo "==> Launching LXD container: $CONTAINER_NAME"
	
	# Stop and delete if exists
	if incus list --format=csv | grep -q "^$CONTAINER_NAME,"; then
		echo "==> Container exists, recreating..."
		incus stop $CONTAINER_NAME --force 2>/dev/null || true
		incus delete $CONTAINER_NAME --force 2>/dev/null || true
	fi
	
	# Launch container
	incus launch images:debian/13/cloud $CONTAINER_NAME -p default -p debian-lxd
	
	echo ""
	echo "==> Container launched. Wait 2-3 minutes for cloud-init."
	echo "==> Check status: incus exec $CONTAINER_NAME -- cloud-init status"
	echo "==> Test Docker: incus exec $CONTAINER_NAME -- docker ps"
	echo "==> Test GPU: incus exec $CONTAINER_NAME -- nvidia-smi"
	echo ""
	echo "==> Access with: incus exec -it $CONTAINER_NAME -- bash"
	echo "==> Stop with: incus stop $CONTAINER_NAME --force"
	echo "==> Delete with: incus delete $CONTAINER_NAME --force"

# Add volume mount to LXD container
lxd-mount container source path:
	#!/usr/bin/env bash
	echo "==> Mounting {{source}} to /{{path}} in {{container}}..."
	incus config device add {{container}} shared-{{path}} disk source={{source}} path=/{{path}}
	echo "==> Volume mounted. Access at /{{path}} inside container."

# Remove volume mount from LXD container
lxd-unmount container path:
	#!/usr/bin/env bash
	echo "==> Removing mount /{{path}} from {{container}}..."
	incus config device remove {{container}} shared-{{path}} 2>/dev/null || echo "Mount not found"

# Show LXD container info
lxd-info name:
	@echo "==> Container: {{name}}"
	@incus list {{name}} --format=table
	@echo ""
	@echo "==> Devices:"
	@incus config device show {{name}}
	@echo ""
	@echo "==> Docker status:"
	@incus exec {{name}} -- systemctl status docker --no-pager || echo "Docker not ready yet"

# Destroy Debian profile
destroy-profile:
  @echo "==> Destroying Debian base profile..."
  @incus profile delete debian-dev 2>/dev/null || echo "Profile not found"

# Test Debian profile with a VM
test-profile:
  @echo "==> Testing profile..."
  @incus launch --vm {{_IMAGE}} test-debian -p default -p debian-dev \
    --config limits.cpu={{_VM_CPU}} \
    --config limits.memory={{_VM_MEMORY}}
  @just wait-for-vm test-debian
  @echo ""
  @echo "==> Test complete. Cleanup with: incus delete test-debian --force"

# Run VM (creates profile if needed, launches with fixed name 'debian-dev')
run-vm: create
  #!/usr/bin/env bash
  VM_NAME="{{_VM_NAME}}"
  CPU="{{_VM_CPU}}"
  MEMORY="{{_VM_MEMORY}}"
  
  echo "==> Running VM: $VM_NAME (CPU: $CPU, Memory: $MEMORY)"
  
  # Stop and delete if exists
  if incus list --format=csv | grep -q "^$VM_NAME,"; then
    echo "==> VM exists, recreating..."
    incus stop $VM_NAME --force 2>/dev/null || true
    incus delete $VM_NAME --force 2>/dev/null || true
  fi
  
  # Launch VM with CPU and memory settings
  incus launch --vm {{_IMAGE}} $VM_NAME -p default -p debian-dev \
    --config limits.cpu=$CPU \
    --config limits.memory=$MEMORY
  
  echo ""
  echo "==> VM launched. Waiting for cloud-init to complete..."
  echo ""
  
  # Wait for VM to be ready
  just wait-for-vm $VM_NAME

# Run VM with small resources (2 CPU, 8GiB RAM)
run-vm-small:
  #!/usr/bin/env bash
  echo "==> Running small VM (2 CPU, 8GiB RAM)..."
  VM_NAME="{{_VM_NAME}}"
  
  # Stop and delete if exists
  if incus list --format=csv | grep -q "^$VM_NAME,"; then
    echo "==> VM exists, recreating..."
    incus stop $VM_NAME --force 2>/dev/null || true
    incus delete $VM_NAME --force 2>/dev/null || true
  fi
  
  # Create profile if needed
  incus profile create debian-dev 2>/dev/null || echo "Profile exists"
  incus profile set debian-dev cloud-init.user-data="$(cat ./cloud-init.yaml)"
  
  # Launch VM with small resources
  incus launch --vm {{_IMAGE}} $VM_NAME -p default -p debian-dev \
    --config limits.cpu={{_VM_CPU_SMALL}} \
    --config limits.memory={{_VM_MEMORY_SMALL}}
  
  echo ""
  just wait-for-vm $VM_NAME

# Run VM with large resources (8 CPU, 32GiB RAM)
run-vm-large:
  #!/usr/bin/env bash
  echo "==> Running large VM (8 CPU, 32GiB RAM)..."
  VM_NAME="{{_VM_NAME}}"
  
  # Stop and delete if exists
  if incus list --format=csv | grep -q "^$VM_NAME,"; then
    echo "==> VM exists, recreating..."
    incus stop $VM_NAME --force 2>/dev/null || true
    incus delete $VM_NAME --force 2>/dev/null || true
  fi
  
  # Create profile if needed
  incus profile create debian-dev 2>/dev/null || echo "Profile exists"
  incus profile set debian-dev cloud-init.user-data="$(cat ./cloud-init.yaml)"
  
  # Launch VM with large resources
  incus launch --vm {{_IMAGE}} $VM_NAME -p default -p debian-dev \
    --config limits.cpu={{_VM_CPU_LARGE}} \
    --config limits.memory={{_VM_MEMORY_LARGE}}
  
  echo ""
  just wait-for-vm $VM_NAME

# Create VM with custom CPU and memory
create-custom name cpu memory:
  #!/usr/bin/env bash
  VM_NAME="{{name}}"
  CPU="{{cpu}}"
  MEMORY="{{memory}}"
  
  echo "==> Creating VM: $VM_NAME (CPU: $CPU, Memory: $MEMORY)"
  
  # Create profile if needed
  incus profile create debian-dev 2>/dev/null || echo "Profile already exists"
  incus profile set debian-dev cloud-init.user-data="$(cat ./cloud-init.yaml)"
  
  # Launch VM with custom CPU and memory
  incus launch --vm {{_IMAGE}} $VM_NAME -p default -p debian-dev \
    --config limits.cpu=$CPU \
    --config limits.memory=$MEMORY
  
  echo ""
  echo "==> VM launched. Waiting for cloud-init to complete..."
  echo ""
  just wait-for-vm $VM_NAME

# Wait for VM to be ready with progress indicator
wait-for-vm name="{{_VM_NAME}}":
  #!/usr/bin/env bash
  VM_NAME="{{name}}"
  echo "==> Waiting for $VM_NAME to be ready..."
  for i in $(seq 1 360); do
    echo -n "[$i/360] Checking VM status... "
    if incus exec $VM_NAME -- cloud-init status 2>/dev/null | grep -q "done"; then
      echo "✅ READY!"
      echo ""
      echo "✅ VM $VM_NAME is ready!"
      echo "   Access with: incus exec -it $VM_NAME -- bash"
      exit 0
    fi
    echo "⏳ Provisioning..."
    sleep 5
  done
  echo "❌ Timeout: VM not ready after 5 minutes"
  echo "   Check logs: incus console $VM_NAME"
  exit 1

# List all development VMs
vm-list:
  @echo "==> Development VMs:"
  @incus list --format=table | grep -E "debian|dev" || echo "No VMs found"

# Quick access to VM shell
vm-shell name="{{_VM_NAME}}":
  @echo "==> Connecting to {{name}}..."
  @incus exec -it {{name}} -- bash

# Show VM resource usage
vm-status name="{{_VM_NAME}}":
  @echo "==> VM: {{name}}"
  @incus list {{name}} --format=table
  @echo ""
  @echo "==> Resource Usage:"
  @incus exec {{name}} -- free -h || true
  @echo ""
  @echo "==> Disk Usage:"
  @incus exec {{name}} -- df -h / || true
